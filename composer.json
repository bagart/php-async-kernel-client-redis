{
    "name": "bagart/ask-client-redis",
    "description": "Fully asynchronous Redis client library built on top of BAGArt/AsyncKernel. Fiber-based, promise-driven, transport-agnostic inside ASK ecosystem.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ASK",
        "async",
        "redis",
        "fiber",
        "promise",
        "pipeline",
        "pubsub",
        "non-blocking",
        "transport"
    ],
    "authors": [
        {
            "name": "BAGArt (Artur Baltaev)",
            "email": "baltaev.artur+ask@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-redis": "*",
        "bagart/async-kernel": "*",
        "bagart/ask-client": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "BAGArt\\ASKClientRedis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BAGArt\\ASKClientRedis\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "../../vendor/bin/pest",
        "analyse": "phpstan analyse src --level=max"
    }
}
